  45:main.c        **** 
  46:main.c        ****     // set up uart for 9600 baud communication with no parity
  47:main.c        **** 	UBRR0H = (uint8_t) (DEF_BAUD_PRESCALE_SLOW>>8);
  48:main.c        **** 	UBRR0L = (uint8_t) DEF_BAUD_PRESCALE_SLOW;
  49:main.c        ****     UCSR0A = ( DEF_BAUD_DOUBLE_SLOW<<U2X0 );
