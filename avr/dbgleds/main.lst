 141:main.c        ****                                 cmdstate = CST_IDLE;
 142:main.c        ****                             }
 143:main.c        ****                         } else if ( inbyte == instaddr ) {
 144:main.c        ****                             numargs = 15;
 145:main.c        ****                             cmdstate = CST_ARGS;
 146:main.c        ****                         }
 147:main.c        ****                         break;
 148:main.c        ****                 }
 149:main.c        ****                 // */
 150:main.c        ****                 break;
