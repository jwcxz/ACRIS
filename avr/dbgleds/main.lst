 122:main.c        ****                  *         the 5-character action keyword
 123:main.c        ****                  * / // <- XXX
 124:main.c        ****                 switch (inbyte) {
 125:main.c        ****                     case CMD_DOALL:
 126:main.c        ****                         numargs = 15;
 127:main.c        ****                         cmdstate = CST_ARGS;
