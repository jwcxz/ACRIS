  39:main.c        **** int main(void) {
  40:main.c        ****     // initialize debug LEDs
  41:main.c        ****     dbg_init();
  42:main.c        **** 
  43:main.c        ****     // get the address of the device
  44:main.c        ****     instaddr = get_addr();
  45:main.c        **** 
  46:main.c        ****     // initialize TLC
  47:main.c        ****     tlc_init();
  48:main.c        **** 
  49:main.c        ****     // initialize UART
  50:main.c        ****     uart_init();
  51:main.c        **** 
  52:main.c        ****     // show address of the device on the debug LEDs
  53:main.c        ****     dbg_set(0xFF);
  54:main.c        ****     _delay_ms(100);
  55:main.c        ****     show_addr();
  56:main.c        **** 
  57:main.c        ****     // enable interrupts
  58:main.c        ****     sei();
  59:main.c        ****     rxen = 1;
  60:main.c        **** 
  61:main.c        ****     while (1) {
  62:main.c        ****         if ( rxen == 0 && uart_rxbuf_count < UART_RX_BUFSZ/2 ) {
  63:main.c        ****             // buffer has been partially depleted, so we can start accepting
  64:main.c        ****             // data again
  65:main.c        ****             rxen = 1;
  66:main.c        ****             sei();
  67:main.c        ****         }
  68:main.c        **** 
  69:main.c        ****         if ( uart_data_rdy() ) receive_data();
  70:main.c        ****     }
  71:main.c        **** 
