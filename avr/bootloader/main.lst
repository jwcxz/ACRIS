   1:main.c        **** /* A C R I S   P R O J E C T ********
   2:main.c        ****  * LED Controller Bootloader        *
   3:main.c        ****  * http://jwcxz.com/projects/acris  *
   4:main.c        ****  *                                  *
   5:main.c        ****  * J. Colosimo -- http://jwcxz.com/ *
   6:main.c        ****  *                                  *
   7:main.c        ****  * Main bootloader source file      *
   8:main.c        ****  ************************************/
   9:main.c        **** 
  10:main.c        **** /*
  11:main.c        ****  * This bootloader provides the following features:
  12:main.c        ****  *  1. fast startup time (i.e. bootloader->application time)
  13:main.c        ****  *  2. downloading of program to device
GAS LISTING /tmp/ccUKiqZN.s 			page 3


  14:main.c        ****  *  3. set address of instrument
  15:main.c        ****  *  4. set the transmission baud rate (via the divisor)
  16:main.c        ****  *  5. set a mask (only operate on some devices)
  17:main.c        ****  *  6. view the instrument address on the debug LEDs
  18:main.c        ****  *  7. program verification
  19:main.c        ****  *
  20:main.c        ****  *  Transmission is done through a serial protocol:
  21:main.c        ****  *  Fn  Args    Description
  22:main.c        ****  *  ___ _______ ____________________________________________________
  23:main.c        ****  *  170 0       SYNC -- start of a packet
  24:main.c        ****  *
  25:main.c        ****  *  N   0       NOP -- sent to wake bootloader up (or you can use SYNC)
  26:main.c        ****  *
  27:main.c        ****  *  A   1       Set 1-byte address of the device in EEPROM
  28:main.c        ****  *
  29:main.c        ****  *  B   2       [High][Low][Double?] -- set divisor and U2XN of the UART in EEPROM
  30:main.c        ****  *
  31:main.c        ****  *  D   0       Show the high nibble of the instrument address on the debug LEDs
  32:main.c        ****  *
  33:main.c        ****  *  E   0       Show the low nibble of the instrument address on the debug LEDs
  34:main.c        ****  *
  35:main.c        ****  *  M   1       [InstAddr] Instrument address to work with for all following commands
  36:main.c        ****  *                  0xFF - all instruments
  37:main.c        ****  *                  0xF0-0xFE - blocks of 16
  38:main.c        ****  *
  39:main.c        ****  *  P   2       [Addr][Page...] - Send program one page at a time
  40:main.c        ****  *                  To simplify the bootloader, it does NOT take an Intel HEX
  41:main.c        ****  *                  file as an input.  Rather, a special "program" script reads
  42:main.c        ****  *                  the HEX file and outputs the following format:
  43:main.c        ****  *                      [Starting Address][Page][Checksum]
  44:main.c        ****  *                  The checksum is the one's complement of the sum of the
  45:main.c        ****  *                  page stream.
  46:main.c        ****  *
  47:main.c        ****  *                  Note: this means that the stream length depends on the page
  48:main.c        ****  *                  size (whereas Intel HEX files have known lengths).
  49:main.c        ****  *                  Furthermore, it requires that unused bytes be 0-filled or
  50:main.c        ****  *                  something.  I'd rather make the programmer
  51:main.c        ****  *
  52:main.c        ****  *  V   1       [Checksum] Verify whole program against checksum.  If
  53:main.c        ****  *              verification fails, write 0xFF to the program start to prevent
  54:main.c        ****  *              the bootloader from loading the application.
  55:main.c        ****  */
  56:main.c        **** 
  57:main.c        **** #include "main.h"
  58:main.c        **** #include "eeprom.h"
  59:main.c        **** #include "dbgled.h"
  60:main.c        **** #include "uart.h"
  61:main.c        **** 
  62:main.c        **** // uart buffer
  63:main.c        **** volatile uint8_t uart_rxbuf[UART_RX_BUFSZ];
  64:main.c        **** volatile uint8_t *uart_rxbuf_iptr = uart_rxbuf;
  65:main.c        **** volatile uint8_t *uart_rxbuf_optr = uart_rxbuf;
  66:main.c        **** volatile uint8_t uart_rxbuf_count = 0;
  67:main.c        **** volatile uint8_t rxen = 1;
  68:main.c        **** 
  69:main.c        **** // current command state
  70:main.c        **** static uint8_t curstate = CST_IDLE;
GAS LISTING /tmp/ccUKiqZN.s 			page 4


  71:main.c        **** 
  72:main.c        **** // page buffer
  73:main.c        **** static uint8_t page_buf[PAGESIZE];
  74:main.c        **** static uint8_t *page_buf_ptr;
  75:main.c        **** static uint8_t page_addr;
  76:main.c        **** 
  77:main.c        **** // instrument address
  78:main.c        **** uint8_t instaddr;
  79:main.c        **** 
  80:main.c        **** // baud rate divisor
  81:main.c        **** static uint16_t baud;
  82:main.c        **** 
  83:main.c        **** // device address mask
  84:main.c        **** static uint8_t mask = AM_ALL;
  85:main.c        **** 
  86:main.c        **** /* Main Loop */
  87:main.c        **** int main(void) {
  88:main.c        ****     instaddr = get_addr();
  89:main.c        **** 
  90:main.c        ****     // set up uart for 9600 baud communication with no parity
  91:main.c        **** 	UBRR0H = (uint8_t) (DEF_BAUD_PRESCALE_SLOW>>8);
  92:main.c        **** 	UBRR0L = (uint8_t) DEF_BAUD_PRESCALE_SLOW;
  93:main.c        ****     UCSR0A = ( _BV(U2X0) );
  94:main.c        **** 	UCSR0B = ( _BV(RXCIE0) | _BV(RXEN0) );
  95:main.c        **** 	UCSR0C = ( _BV(UCSZ01) | _BV(UCSZ00) );
  96:main.c        **** 
  97:main.c        ****     // reset the pointers and buffer count
  98:main.c        **** 	uart_rxbuf_iptr = uart_rxbuf;
  99:main.c        **** 	uart_rxbuf_optr = uart_rxbuf;
 100:main.c        ****     uart_rxbuf_count = 0;
 101:main.c        **** 
 102:main.c        ****     sei();
 103:main.c        **** 
 104:main.c        ****     // wait just a bit to get some data
 105:main.c        ****     _delay_ms(1);
 106:main.c        **** 
 107:main.c        ****     // switch to application mode if there's no data on the UART
 108:main.c        ****     if ( !uart_data_rdy() ) {
 109:main.c        ****         cli();
 110:main.c        ****         asm("jmp 0000");
 111:main.c        ****     } else {
 112:main.c        ****         // otherwise, go into receive data loop
 113:main.c        ****         receive_data();
 114:main.c        ****     }
 115:main.c        **** 
 116:main.c        ****     return 0;
 117:main.c        **** }
 118:main.c        **** 
 119:main.c        **** /* Loop, waiting for data */
 120:main.c        **** void receive_data(void) {
 121:main.c        ****     while (1) {
 122:main.c        ****         if ( uart_data_rdy() ) process_rx();
 123:main.c        ****     }
 124:main.c        **** }
 125:main.c        **** 
 126:main.c        **** /* Processed a received byte */
 127:main.c        **** void process_rx(void) {
GAS LISTING /tmp/ccUKiqZN.s 			page 5


 128:main.c        ****     uint8_t data, i;
 129:main.c        ****     uint8_t csum = 0;
 130:main.c        ****     data = uart_rx();
 131:main.c        **** 
 132:main.c        ****     if ( data != CMD_NOP ) {
 133:main.c        ****         switch (curstate) {
 134:main.c        ****             case CST_IDLE:
 135:main.c        ****                 if ( data == CMD_SYNC ) curstate = CST_SYNC;
 136:main.c        ****                 else curstate = CST_IDLE;
 137:main.c        ****                 break;
 138:main.c        ****             case CST_SYNC:
 139:main.c        ****                 if ( data == CMD_SYNC ) curstate = CST_SYNC;
 140:main.c        ****                     // if we get a mask request, then always honor it
 141:main.c        ****                 else if ( data == CMD_MASK ) curstate = CST_MASK;
 142:main.c        ****                 else if ( applies_to_me() ) {
 143:main.c        ****                     switch (data) {
 144:main.c        ****                         case CMD_DISP_ADDR_H:
 145:main.c        ****                             dbg_set(instaddr>>4);
 146:main.c        ****                             curstate = CST_IDLE;
 147:main.c        ****                             break;
 148:main.c        ****                         case CMD_DISP_ADDR_L:
 149:main.c        ****                             dbg_set(instaddr&0x0F);
 150:main.c        ****                             curstate = CST_IDLE;
 151:main.c        ****                             break;
 152:main.c        **** 
 153:main.c        ****                         case CMD_ADDR:
 154:main.c        ****                             curstate = CST_ADDR;
 155:main.c        ****                             break;
 156:main.c        **** 
 157:main.c        ****                         case CMD_BAUD:
 158:main.c        ****                             curstate = CST_BAUD_H;
 159:main.c        ****                             break;
 160:main.c        **** 
 161:main.c        ****                         case CMD_PROG:
 162:main.c        ****                             curstate = CST_PROG_A;
 163:main.c        ****                             break;
 164:main.c        **** 
 165:main.c        ****                         case CMD_VRFY:
 166:main.c        ****                             curstate = CST_VRFY;
 167:main.c        ****                             break;
 168:main.c        **** 
 169:main.c        ****                         default:
 170:main.c        ****                             curstate = CST_IDLE;
 171:main.c        ****                             break;
 172:main.c        ****                     }
 173:main.c        ****                 } 
 174:main.c        ****                 // otherwise, no action applied to me, so wait for the next
 175:main.c        ****                 // packet (maybe it'll be a new mask)
 176:main.c        ****                 else curstate = CST_IDLE;
 177:main.c        ****                 break;
 178:main.c        **** 
 179:main.c        ****             case CST_MASK:
 180:main.c        ****                 mask = data;
 181:main.c        ****                 curstate = CST_IDLE;
 182:main.c        ****                 break;
 183:main.c        **** 
 184:main.c        ****             case CST_ADDR:
GAS LISTING /tmp/ccUKiqZN.s 			page 6


 185:main.c        ****                 addr_set(data);
 186:main.c        ****                 curstate = CST_IDLE;
 187:main.c        ****                 break;
 188:main.c        **** 
 189:main.c        ****             case CST_BAUD_H:
 190:main.c        ****                 baud = (data << 8);   // high byte of baud rate
 191:main.c        ****                 curstate = CST_BAUD_L;
 192:main.c        ****                 break;
 193:main.c        ****             case CST_BAUD_L:
 194:main.c        ****                 baud |= data;         // low byte of baud rate
 195:main.c        ****                 curstate = CST_BAUD_D;
 196:main.c        ****                 break;
 197:main.c        ****             case CST_BAUD_D:
 198:main.c        ****                 // TODO: save some space by always setting double to 1
 199:main.c        ****                 baud_set(data);
 200:main.c        ****                 curstate = CST_IDLE;
 201:main.c        ****                 break;
 202:main.c        **** 
 203:main.c        ****             case CST_PROG_A:
 204:main.c        ****                 page_addr = data;
 205:main.c        ****                 // reset page buffer pointer
 206:main.c        ****                 page_buf_ptr = page_buf;
 207:main.c        ****                 curstate = CST_PROG_D;
 208:main.c        ****             case CST_PROG_D:
 209:main.c        ****                 *page_buf_ptr++ = data;
 210:main.c        ****                 if ( page_buf_ptr - page_buf == PAGESIZE ) {
 211:main.c        ****                     // we hit the last byte of the page, so the next byte is the
 212:main.c        ****                     // checksum
 213:main.c        ****                     curstate = CST_PROG_V;
 214:main.c        ****                 } else {
 215:main.c        ****                     curstate = CST_PROG_D;
 216:main.c        ****                 }
 217:main.c        ****                 break;
 218:main.c        ****             case CST_PROG_V:
 219:main.c        ****                 curstate = CST_IDLE;
 220:main.c        **** 
 221:main.c        ****                 for ( i=0 ; i<PAGESIZE ; i++ ) {
 222:main.c        ****                     csum += page_buf[i];
 223:main.c        ****                 }
 224:main.c        ****                 csum = ~csum;
 225:main.c        **** 
 226:main.c        ****                 if ( csum == data ) {
 227:main.c        ****                     // checksum verifies, so write the page
 228:main.c        ****                     write_page();
 229:main.c        ****                 } else {
 230:main.c        ****                     // damnit...
 231:main.c        ****                     // TODO: we can be slightly smarter (if it's the first address,
 232:main.c        ****                     // we technically haven't corrupted anything yet)
 233:main.c        ****                     give_up(1);
 234:main.c        ****                 }
 235:main.c        **** 
 236:main.c        ****             case CST_VRFY:
 237:main.c        ****                 verify_flash(data);
 238:main.c        ****                 break;
 239:main.c        **** 
 240:main.c        ****             default:
 241:main.c        ****                 curstate = CST_IDLE;
GAS LISTING /tmp/ccUKiqZN.s 			page 7


 242:main.c        ****                 break;
 243:main.c        ****         }
 244:main.c        ****     }
 245:main.c        **** }
 246:main.c        **** 
 247:main.c        **** /* Reached an unrecoverable error, so:
 248:main.c        ****  *  - Light up the LEDs indicating an error
 249:main.c        ****  *  - If corrupted, then write 0xFF to the first page in order to prevent the
 250:main.c        ****  *    bootloader from trying to run the application at the beginning.
 251:main.c        ****  *  - Go back and wait for new data.
 252:main.c        ****  */
 253:main.c        **** void give_up(uint8_t corrupted) {
 254:main.c        ****     // if application data was corrupted, fill the first page with 0xFF
 255:main.c        ****     if (corrupted) {
 256:main.c        ****         // set LEDs to "shit really hit the fan"
 257:main.c        ****         dbg_set(0xA);
 258:main.c        ****         // TODO: fill the first page with 0xFF
 259:main.c        ****     } else {
 260:main.c        ****         // set LEDs to "shit slightly hit the fan"
 261:main.c        ****         dbg_set(0x9);
