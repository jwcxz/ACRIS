   1:main.c        **** /* A C R I S   P R O J E C T ********
   2:main.c        ****  * LED Controller Bootloader        *
   3:main.c        ****  * http://jwcxz.com/projects/acris  *
   4:main.c        ****  *                                  *
   5:main.c        ****  * J. Colosimo -- http://jwcxz.com/ *
   6:main.c        ****  *                                  *
   7:main.c        ****  * Main bootloader source file      *
   8:main.c        ****  ************************************/
   9:main.c        **** 
  10:main.c        **** /*
  11:main.c        ****  * This bootloader provides the following features:
  12:main.c        ****  *  1. fast startup time (i.e. bootloader->application time)
  13:main.c        ****  *  2. downloading of program to device
GAS LISTING /tmp/ccdNGuN3.s 			page 3


  14:main.c        ****  *  3. set address of instrument
  15:main.c        ****  *  4. set the transmission baud rate (via the divisor)
  16:main.c        ****  *  5. set a mask (only operate on some devices)
  17:main.c        ****  *  6. view the instrument address on the debug LEDs
  18:main.c        ****  *  7. program verification
  19:main.c        ****  *
  20:main.c        ****  *  Transmission is done through a serial protocol:
  21:main.c        ****  *  Fn  Args    Description
  22:main.c        ****  *  ___ _______ ____________________________________________________
  23:main.c        ****  *  170 0       SYNC -- start of a packet
  24:main.c        ****  *
  25:main.c        ****  *  N   0       NOP -- sent to wake bootloader up (or you can use SYNC)
  26:main.c        ****  *
  27:main.c        ****  *  A   1       Set 1-byte address of the device in EEPROM
  28:main.c        ****  *
  29:main.c        ****  *  B   2       [High][Low][Double?] -- set divisor and U2XN of the UART in EEPROM
  30:main.c        ****  *
  31:main.c        ****  *  D   0       Show the high nibble of the instrument address on the debug LEDs
  32:main.c        ****  *
  33:main.c        ****  *  E   0       Show the low nibble of the instrument address on the debug LEDs
  34:main.c        ****  *
  35:main.c        ****  *  M   1       [InstAddr] Instrument address to work with for all following commands
  36:main.c        ****  *                  0xFF - all instruments
  37:main.c        ****  *                  0xF0-0xFE - blocks of 16
  38:main.c        ****  *
  39:main.c        ****  *  P   2       [Addr][Page...] - Send program one page at a time
  40:main.c        ****  *                  To simplify the bootloader, it does NOT take an Intel HEX
  41:main.c        ****  *                  file as an input.  Rather, a special "program" script reads
  42:main.c        ****  *                  the HEX file and outputs the following format:
  43:main.c        ****  *                      [Starting Address][Page][Checksum]
  44:main.c        ****  *                  The checksum is the one's complement of the sum of the
  45:main.c        ****  *                  page stream.
  46:main.c        ****  *
  47:main.c        ****  *                  Note: this means that the stream length depends on the page
  48:main.c        ****  *                  size (whereas Intel HEX files have known lengths).
  49:main.c        ****  *                  Furthermore, it requires that unused bytes be 0-filled or
  50:main.c        ****  *                  something.  I'd rather make the programmer
  51:main.c        ****  *
  52:main.c        ****  *  V   1       [Checksum] Verify whole program against checksum.  If
  53:main.c        ****  *              verification fails, write 0xFF to the program start to prevent
  54:main.c        ****  *              the bootloader from loading the application.
  55:main.c        ****  */
  56:main.c        **** 
  57:main.c        **** #include "main.h"
  58:main.c        **** #include "eeprom.h"
  59:main.c        **** #include "dbgled.h"
  60:main.c        **** #include "uart.h"
  61:main.c        **** 
  62:main.c        **** // uart buffer
  63:main.c        **** volatile uint8_t uart_rxbuf[UART_RX_BUFSZ];
  64:main.c        **** volatile uint8_t *uart_rxbuf_iptr = uart_rxbuf;
  65:main.c        **** volatile uint8_t *uart_rxbuf_optr = uart_rxbuf;
  66:main.c        **** volatile uint8_t uart_rxbuf_count = 0;
  67:main.c        **** 
  68:main.c        **** // current command state
  69:main.c        **** static uint8_t curstate = CST_IDLE;
  70:main.c        **** 
GAS LISTING /tmp/ccdNGuN3.s 			page 4


  71:main.c        **** // page buffer
  72:main.c        **** static uint8_t page_buf[PAGESIZE];
  73:main.c        **** static uint8_t* page_buf_ptr;
  74:main.c        **** static uint8_t page_addr;
  75:main.c        **** 
  76:main.c        **** // instrument address
  77:main.c        **** uint8_t instaddr;
  78:main.c        **** 
  79:main.c        **** // baud rate divisor
  80:main.c        **** static uint16_t baud;
  81:main.c        **** 
  82:main.c        **** // device address mask
  83:main.c        **** static uint8_t mask = AM_ALL;
  84:main.c        **** 
  85:main.c        **** /* Main Loop */
  86:main.c        **** int main(void) {
  87:main.c        ****     instaddr = get_addr();
  88:main.c        **** 
  89:main.c        ****     // set up uart for 9600 baud communication with no parity
  90:main.c        **** 	UBRR0H = (unsigned char) (DEF_BAUD_PRESCALE_SLOW>>8);
  91:main.c        **** 	UBRR0L = (unsigned char) DEF_BAUD_PRESCALE_SLOW;
  92:main.c        ****     UCSR0A = ( _BV(U2X0) );
  93:main.c        **** 	UCSR0B = ( _BV(RXCIE0) | _BV(RXEN0) );
  94:main.c        **** 	UCSR0C = ( _BV(UCSZ01) | _BV(UCSZ00) );
  95:main.c        **** 
  96:main.c        ****     // reset the pointers and buffer count
  97:main.c        **** 	uart_rxbuf_iptr = uart_rxbuf;
  98:main.c        **** 	uart_rxbuf_optr = uart_rxbuf;
  99:main.c        ****     uart_rxbuf_count = 0;
 100:main.c        **** 
 101:main.c        ****     // switch to application mode if there's no data on the UART
 102:main.c        ****     if ( !uart_data_rdy() ) {
 103:main.c        ****         cli();
 104:main.c        ****         asm("jmp 0000");
 105:main.c        ****     } else {
 106:main.c        ****         // otherwise, go into receive data loop
 107:main.c        ****         receive_data();
 108:main.c        ****     }
 109:main.c        **** 
 110:main.c        ****     return 0;
 111:main.c        **** }
 112:main.c        **** 
 113:main.c        **** /* Loop, waiting for data */
 114:main.c        **** void receive_data(void) {
 115:main.c        ****     while (1) {
 116:main.c        ****         if ( uart_data_rdy() ) process_rx();
 117:main.c        ****     }
 118:main.c        **** }
 119:main.c        **** 
 120:main.c        **** /* Processed a received byte */
 121:main.c        **** void process_rx(void) {
 122:main.c        ****     uint8_t data, i;
 123:main.c        ****     uint8_t csum = 0;
 124:main.c        ****     data = uart_rx();
 125:main.c        **** 
 126:main.c        ****     if ( data != CMD_NOP ) {
 127:main.c        ****         switch (curstate) {
GAS LISTING /tmp/ccdNGuN3.s 			page 5


 128:main.c        ****             case CST_IDLE:
 129:main.c        ****                 if ( data == CMD_SYNC ) curstate = CST_SYNC;
 130:main.c        ****                 else curstate = CST_IDLE;
 131:main.c        ****                 break;
 132:main.c        ****             case CST_SYNC:
 133:main.c        ****                 if ( data == CMD_SYNC ) {
 134:main.c        ****                     curstate = CST_SYNC;
 135:main.c        ****                 } else if ( data == CMD_MASK ) {
 136:main.c        ****                     // if we get a mask request, then always honor it
 137:main.c        ****                     curstate = CST_MASK;
 138:main.c        ****                 } else if ( applies_to_me() ) {
 139:main.c        ****                     switch (data) {
 140:main.c        ****                         case CMD_DISP_ADDR_H:
 141:main.c        ****                             dbg_set(instaddr>>4);
 142:main.c        ****                             curstate = CST_IDLE;
 143:main.c        ****                             break;
 144:main.c        ****                         case CMD_DISP_ADDR_L:
 145:main.c        ****                             dbg_set(instaddr&0x0F);
 146:main.c        ****                             curstate = CST_IDLE;
 147:main.c        ****                             break;
 148:main.c        **** 
 149:main.c        ****                         case CMD_ADDR:
 150:main.c        ****                             curstate = CST_ADDR;
 151:main.c        ****                             break;
 152:main.c        **** 
 153:main.c        ****                         case CMD_BAUD:
 154:main.c        ****                             curstate = CST_BAUD_H;
 155:main.c        ****                             break;
 156:main.c        **** 
 157:main.c        ****                         case CMD_PROG:
 158:main.c        ****                             curstate = CST_PROG_A;
 159:main.c        ****                             break;
 160:main.c        **** 
 161:main.c        ****                         case CMD_VRFY:
 162:main.c        ****                             curstate = CST_VRFY;
 163:main.c        ****                             break;
 164:main.c        **** 
 165:main.c        ****                         default:
 166:main.c        ****                             curstate = CST_IDLE;
 167:main.c        ****                             break;
 168:main.c        ****                     }
 169:main.c        ****                 } else {
 170:main.c        ****                     // no action applied to me, so wait for the next packet
 171:main.c        ****                     // (maybe it'll be a new mask)
 172:main.c        ****                     curstate = CST_IDLE;
 173:main.c        ****                 }
 174:main.c        ****                 break;
 175:main.c        **** 
 176:main.c        ****             case CST_MASK:
 177:main.c        ****                 mask = data;
 178:main.c        ****                 curstate = CST_IDLE;
 179:main.c        ****                 break;
 180:main.c        **** 
 181:main.c        ****             case CST_ADDR:
 182:main.c        ****                 addr_set(data);
 183:main.c        ****                 curstate = CST_IDLE;
 184:main.c        ****                 break;
GAS LISTING /tmp/ccdNGuN3.s 			page 6


 185:main.c        **** 
 186:main.c        ****             case CST_BAUD_H:
 187:main.c        ****                 baud = (data << 8);   // high byte of baud rate
 188:main.c        ****                 curstate = CST_BAUD_L;
 189:main.c        ****                 break;
 190:main.c        ****             case CST_BAUD_L:
 191:main.c        ****                 baud |= data;         // low byte of baud rate
 192:main.c        ****                 curstate = CST_BAUD_D;
 193:main.c        ****                 break;
 194:main.c        ****             case CST_BAUD_D:
 195:main.c        ****                 // TODO: save some space by always setting double to 1
 196:main.c        ****                 baud_set(data);
 197:main.c        ****                 curstate = CST_IDLE;
 198:main.c        ****                 break;
 199:main.c        **** 
 200:main.c        ****             case CST_PROG_A:
 201:main.c        ****                 page_addr = data;
 202:main.c        ****                 // reset page buffer pointer
 203:main.c        ****                 page_buf_ptr = page_buf;
 204:main.c        ****                 curstate = CST_PROG_D;
 205:main.c        ****             case CST_PROG_D:
 206:main.c        ****                 *page_buf_ptr++ = data;
 207:main.c        ****                 if ( page_buf_ptr - page_buf == PAGESIZE ) {
 208:main.c        ****                     // we hit the last byte of the page, so the next byte is the
 209:main.c        ****                     // checksum
 210:main.c        ****                     curstate = CST_PROG_V;
 211:main.c        ****                 } else {
 212:main.c        ****                     curstate = CST_PROG_D;
 213:main.c        ****                 }
 214:main.c        ****                 break;
 215:main.c        ****             case CST_PROG_V:
 216:main.c        ****                 curstate = CST_IDLE;
 217:main.c        **** 
 218:main.c        ****                 for ( i=0 ; i<PAGESIZE ; i++ ) {
 219:main.c        ****                     csum += page_buf[i];
 220:main.c        ****                 }
 221:main.c        ****                 csum = ~csum;
 222:main.c        **** 
 223:main.c        ****                 if ( csum == data ) {
 224:main.c        ****                     // checksum verifies, so write the page
 225:main.c        ****                     write_page();
 226:main.c        ****                 } else {
 227:main.c        ****                     // damnit...
 228:main.c        ****                     // TODO: we can be slightly smarter (if it's the first address,
 229:main.c        ****                     // we technically haven't corrupted anything yet)
 230:main.c        ****                     give_up(1);
 231:main.c        ****                 }
 232:main.c        **** 
 233:main.c        ****             case CST_VRFY:
 234:main.c        ****                 verify_flash(data);
 235:main.c        ****                 break;
 236:main.c        **** 
 237:main.c        ****             default:
 238:main.c        ****                 curstate = CST_IDLE;
 239:main.c        ****                 break;
 240:main.c        ****         }
 241:main.c        ****     }
GAS LISTING /tmp/ccdNGuN3.s 			page 7


 242:main.c        **** }
 243:main.c        **** 
 244:main.c        **** /* Reached an unrecoverable error, so:
 245:main.c        ****  *  - Light up the LEDs indicating an error
 246:main.c        ****  *  - If corrupted, then write 0xFF to the first page in order to prevent the
 247:main.c        ****  *    bootloader from trying to run the application at the beginning.
 248:main.c        ****  *  - Go back and wait for new data.
 249:main.c        ****  */
 250:main.c        **** void give_up(uint8_t corrupted) {
 251:main.c        ****     // if application data was corrupted, fill the first page with 0xFF
 252:main.c        ****     if (corrupted) {
 253:main.c        ****         // set LEDs to "shit really hit the fan"
 254:main.c        ****         dbg_set(0xA);
 255:main.c        ****         // TODO: fill the first page with 0xFF
 256:main.c        ****     } else {
 257:main.c        ****         // set LEDs to "shit slightly hit the fan"
 258:main.c        ****         dbg_set(0x9);
 259:main.c        ****     }
 260:main.c        **** 
 261:main.c        ****     // return to waiting for data
 262:main.c        ****     curstate = CST_IDLE;    // reset state machine
