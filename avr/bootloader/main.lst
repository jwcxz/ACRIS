   1:main.c        **** /* A C R I S   P R O J E C T ********
   2:main.c        ****  * LED Controller Bootloader        *
   3:main.c        ****  * http://jwcxz.com/projects/acris  *
   4:main.c        ****  *                                  *
   5:main.c        ****  * J. Colosimo -- http://jwcxz.com/ *
   6:main.c        ****  *                                  *
   7:main.c        ****  * Main bootloader source file      *
   8:main.c        ****  ************************************/
   9:main.c        **** 
  10:main.c        **** /*
  11:main.c        ****  * This bootloader provides the following features:
  12:main.c        ****  *  1. fast startup time (i.e. bootloader->application time)
  13:main.c        ****  *  2. downloading of program to device
GAS LISTING /tmp/cch8wAQa.s 			page 3


  14:main.c        ****  *  3. set address of instrument
  15:main.c        ****  *  4. set the transmission baud rate (via the divisor)
  16:main.c        ****  *  5. set a mask (only operate on some devices)
  17:main.c        ****  *  6. view the instrument address on the debug LEDs
  18:main.c        ****  *  7. program verification
  19:main.c        ****  *
  20:main.c        ****  *  Transmission is done through a serial protocol:
  21:main.c        ****  *  Fn  Args    Description
  22:main.c        ****  *  ___ _______ ____________________________________________________
  23:main.c        ****  *  170 0       SYNC -- start of a packet
  24:main.c        ****  *
  25:main.c        ****  *  N   0       NOP -- sent to wake bootloader up (or you can use SYNC)
  26:main.c        ****  *
  27:main.c        ****  *  A   1       Set 1-byte address of the device in EEPROM
  28:main.c        ****  *
  29:main.c        ****  *  B   2       [High][Low][Double?] -- set divisor and U2XN of the UART in EEPROM
  30:main.c        ****  *
  31:main.c        ****  *  D   0       Show the high nibble of the instrument address on the debug LEDs
  32:main.c        ****  *
  33:main.c        ****  *  E   0       Show the low nibble of the instrument address on the debug LEDs
  34:main.c        ****  *
  35:main.c        ****  *  M   1       [InstAddr] Instrument address to work with for all following commands
  36:main.c        ****  *                  0xFF - all instruments
  37:main.c        ****  *                  0xF0-0xFE - blocks of 16
  38:main.c        ****  *
  39:main.c        ****  *  P   2       [Addr][Page...] - Send program one page at a time
  40:main.c        ****  *                  To simplify the bootloader, it does NOT take an Intel HEX
  41:main.c        ****  *                  file as an input.  Rather, a special "program" script reads
  42:main.c        ****  *                  the HEX file and outputs the following format:
  43:main.c        ****  *                      [Starting Address][Page][Checksum]
  44:main.c        ****  *                  The checksum is the one's complement of the sum of the
  45:main.c        ****  *                  page stream.
  46:main.c        ****  *
  47:main.c        ****  *                  Note: this means that the stream length depends on the page
  48:main.c        ****  *                  size (whereas Intel HEX files have known lengths).
  49:main.c        ****  *                  Furthermore, it requires that unused bytes be 0-filled or
  50:main.c        ****  *                  something.  I'd rather make the programmer
  51:main.c        ****  *
  52:main.c        ****  *  R   0       BOOT - boot the application
  53:main.c        ****  */
  54:main.c        **** 
  55:main.c        **** #include "main.h"
  56:main.c        **** #include "eeprom.h"
  57:main.c        **** #include "dbgled.h"
  58:main.c        **** #include "uart.h"
  59:main.c        **** 
  60:main.c        **** // uart buffer
  61:main.c        **** volatile uint8_t uart_rxbuf[UART_RX_BUFSZ];
  62:main.c        **** volatile uint8_t *uart_rxbuf_iptr = uart_rxbuf;
  63:main.c        **** volatile uint8_t *uart_rxbuf_optr = uart_rxbuf;
  64:main.c        **** volatile uint8_t uart_rxbuf_count = 0;
  65:main.c        **** volatile uint8_t rxen = 1;
  66:main.c        **** 
  67:main.c        **** // current command state
  68:main.c        **** static uint8_t curstate = CST_IDLE;
  69:main.c        **** 
  70:main.c        **** // page buffer
GAS LISTING /tmp/cch8wAQa.s 			page 4


  71:main.c        **** static uint8_t page_buf[PAGESIZE];
  72:main.c        **** static uint8_t *page_buf_ptr;
  73:main.c        **** static uint16_t page_addr;
  74:main.c        **** 
  75:main.c        **** // instrument address
  76:main.c        **** uint8_t instaddr;
  77:main.c        **** 
  78:main.c        **** // baud rate divisor
  79:main.c        **** static uint16_t baud;
  80:main.c        **** 
  81:main.c        **** // device address mask
  82:main.c        **** static uint8_t mask = AM_ALL;
  83:main.c        **** 
  84:main.c        **** /* Main Loop */
  85:main.c        **** int main(void) {
  86:main.c        ****     MCUCR = (1<<IVCE);
  87:main.c        ****     MCUCR = (1<<IVSEL);
  88:main.c        **** 
  89:main.c        ****     dbg_init();
  90:main.c        ****     dbg_set(0x9);
  91:main.c        **** 
  92:main.c        ****     instaddr = get_addr();
  93:main.c        **** 
  94:main.c        ****     // set up uart for 9600 baud communication with no parity
  95:main.c        **** 	UBRR0H = (uint8_t) (DEF_BAUD_PRESCALE_SLOW>>8);
  96:main.c        **** 	UBRR0L = (uint8_t) DEF_BAUD_PRESCALE_SLOW;
  97:main.c        ****     UCSR0A = ( DEF_BAUD_DOUBLE_SLOW<<U2X0 );
  98:main.c        **** 	UCSR0B = ( _BV(RXCIE0) | _BV(RXEN0) );
  99:main.c        **** 	UCSR0C = ( _BV(UCSZ01) | _BV(UCSZ00) );
 100:main.c        **** 
 101:main.c        ****     // reset the pointers and buffer count
 102:main.c        **** 	uart_rxbuf_iptr = uart_rxbuf;
 103:main.c        **** 	uart_rxbuf_optr = uart_rxbuf;
 104:main.c        ****     uart_rxbuf_count = 0;
 105:main.c        **** 
 106:main.c        ****     sei();
 107:main.c        **** 
 108:main.c        ****     // wait just a bit to get some data
 109:main.c        ****     _delay_ms(500);
 110:main.c        **** 
 111:main.c        ****     // switch to application mode if there's no data on the UART
 112:main.c        ****     if ( !uart_data_rdy() ) {
 113:main.c        ****         cli();
 114:main.c        ****         MCUCR = (1<<IVCE);
 115:main.c        ****         MCUCR = 0;
 116:main.c        ****         asm("jmp 0000");
 117:main.c        ****     } else if ( uart_rx() != CMD_NOP ) {
 118:main.c        ****         cli();
 119:main.c        ****         MCUCR = (1<<IVCE);
 120:main.c        ****         MCUCR = 0;
 121:main.c        ****         asm("jmp 0000");
 122:main.c        ****     } else {
 123:main.c        ****         // otherwise, go into receive data loop
 124:main.c        ****         receive_data();
 125:main.c        ****     }
 126:main.c        **** 
 127:main.c        ****     return 0;
GAS LISTING /tmp/cch8wAQa.s 			page 5


 128:main.c        **** }
 129:main.c        **** 
 130:main.c        **** /* Loop, waiting for data */
 131:main.c        **** void receive_data(void) {
 132:main.c        ****     while (1) {
 133:main.c        ****         if ( uart_data_rdy() ) process_rx();
 134:main.c        ****     }
 135:main.c        **** }
 136:main.c        **** 
 137:main.c        **** /* Processed a received byte */
 138:main.c        **** void process_rx(void) {
 139:main.c        ****     uint8_t data, i;
 140:main.c        ****     uint8_t csum = 0;
 141:main.c        ****     data = uart_rx();
 142:main.c        **** 
 143:main.c        ****     if ( data != CMD_NOP ) {
 144:main.c        ****         switch (curstate) {
 145:main.c        ****             case CST_IDLE:
 146:main.c        ****                 if ( data == CMD_SYNC ) curstate = CST_SYNC;
 147:main.c        ****                 else curstate = CST_IDLE;
 148:main.c        ****                 break;
 149:main.c        ****             case CST_SYNC:
 150:main.c        ****                 if ( data == CMD_SYNC ) curstate = CST_SYNC;
 151:main.c        ****                     // if we get a mask request, then always honor it
 152:main.c        ****                 else if ( data == CMD_MASK ) curstate = CST_MASK;
 153:main.c        ****                 else if ( applies_to_me() ) {
 154:main.c        ****                     switch (data) {
 155:main.c        ****                         case CMD_BOOT:
 156:main.c        ****                             cli();
 157:main.c        ****                             boot_rww_enable_safe();
 158:main.c        ****                             MCUCR = (1<<IVCE);
 159:main.c        ****                             MCUCR = 0;
 160:main.c        ****                             asm("jmp 0000");
 161:main.c        ****                             curstate = CST_IDLE;
 162:main.c        ****                             break;
 163:main.c        ****                             
 164:main.c        ****                         case CMD_DISP_ADDR_H:
 165:main.c        ****                             dbg_set(instaddr>>4);
 166:main.c        ****                             curstate = CST_IDLE;
 167:main.c        ****                             break;
 168:main.c        ****                         case CMD_DISP_ADDR_L:
 169:main.c        ****                             dbg_set(instaddr&0x0F);
 170:main.c        ****                             curstate = CST_IDLE;
 171:main.c        ****                             break;
 172:main.c        **** 
 173:main.c        ****                         case CMD_ADDR:
 174:main.c        ****                             curstate = CST_ADDR;
 175:main.c        ****                             break;
 176:main.c        **** 
 177:main.c        ****                         case CMD_BAUD:
 178:main.c        ****                             curstate = CST_BAUD_H;
 179:main.c        ****                             break;
 180:main.c        **** 
 181:main.c        ****                         case CMD_PROG:
 182:main.c        ****                             curstate = CST_PROG_A_H;
 183:main.c        ****                             break;
 184:main.c        **** 
GAS LISTING /tmp/cch8wAQa.s 			page 6


 185:main.c        ****                         case CMD_FNSH:
 186:main.c        ****                             boot_rww_enable_safe();
 187:main.c        ****                             curstate = CST_IDLE;
 188:main.c        ****                             break;
 189:main.c        **** 
 190:main.c        ****                         default:
 191:main.c        ****                             curstate = CST_IDLE;
 192:main.c        ****                             break;
 193:main.c        ****                     }
 194:main.c        ****                 } 
 195:main.c        ****                 // otherwise, no action applied to me, so wait for the next
 196:main.c        ****                 // packet (maybe it'll be a new mask)
 197:main.c        ****                 else curstate = CST_IDLE;
 198:main.c        ****                 break;
 199:main.c        **** 
 200:main.c        ****             case CST_MASK:
 201:main.c        ****                 mask = data;
 202:main.c        ****                 curstate = CST_IDLE;
 203:main.c        ****                 break;
 204:main.c        **** 
 205:main.c        ****             case CST_ADDR:
 206:main.c        ****                 addr_set(data);
 207:main.c        ****                 curstate = CST_IDLE;
 208:main.c        ****                 instaddr = get_addr();
 209:main.c        ****                 break;
 210:main.c        **** 
 211:main.c        ****             case CST_BAUD_H:
 212:main.c        ****                 baud = (data << 8);   // high byte of baud rate
 213:main.c        ****                 curstate = CST_BAUD_L;
 214:main.c        ****                 break;
 215:main.c        ****             case CST_BAUD_L:
 216:main.c        ****                 baud |= data;         // low byte of baud rate
 217:main.c        ****                 curstate = CST_BAUD_D;
 218:main.c        ****                 break;
 219:main.c        ****             case CST_BAUD_D:
 220:main.c        ****                 // TODO: save some space by always setting double to 1
 221:main.c        ****                 baud_set(data);
 222:main.c        ****                 curstate = CST_IDLE;
 223:main.c        ****                 break;
 224:main.c        **** 
 225:main.c        ****             case CST_PROG_A_H:
 226:main.c        ****                 dbg_set(data);
 227:main.c        ****                 page_addr = data << 8;
 228:main.c        ****                 // reset page buffer pointer
 229:main.c        ****                 page_buf_ptr = page_buf;
 230:main.c        ****                 curstate = CST_PROG_A_L;
 231:main.c        ****                 break;
 232:main.c        ****             case CST_PROG_A_L:
 233:main.c        ****                 //dbg_set(data);    // not useful
 234:main.c        ****                 page_addr |= data;
 235:main.c        ****                 curstate = CST_PROG_D;
 236:main.c        ****                 break;
 237:main.c        ****             case CST_PROG_D:
 238:main.c        ****                 *(page_buf_ptr++) = data;
 239:main.c        ****                 if ( page_buf_ptr - page_buf == PAGESIZE ) {
 240:main.c        ****                     // we hit the last byte of the page, so the next byte is the
 241:main.c        ****                     // checksum
GAS LISTING /tmp/cch8wAQa.s 			page 7


 242:main.c        ****                     curstate = CST_PROG_V;
 243:main.c        ****                 } else {
 244:main.c        ****                     curstate = CST_PROG_D;
 245:main.c        ****                 }
 246:main.c        ****                 break;
 247:main.c        ****             case CST_PROG_V:
 248:main.c        ****                 curstate = CST_IDLE;
 249:main.c        **** 
 250:main.c        ****                 for ( i=0 ; i<PAGESIZE ; i++ ) {
 251:main.c        ****                     csum += page_buf[i];
 252:main.c        ****                 }
 253:main.c        ****                 csum = ~csum;
 254:main.c        **** 
 255:main.c        ****                 if ( csum == data ) {
 256:main.c        ****                     // checksum verifies, so write the page
 257:main.c        ****                     write_page();
 258:main.c        ****                 } else {
 259:main.c        ****                     // damnit...
 260:main.c        ****                     // TODO: we can be slightly smarter (if it's the first address,
