 273:main.c        **** 
 274:main.c        **** /* Reached an unrecoverable error, so:
 275:main.c        ****  *  - Light up the LEDs indicating an error
 276:main.c        ****  *  - If corrupted, then write 0xFF to the first page in order to prevent the
 277:main.c        ****  *    bootloader from trying to run the application at the beginning.
 278:main.c        ****  *  - Go back and wait for new data.
 279:main.c        ****  */
 280:main.c        **** void give_up(uint8_t corrupted) {
 281:main.c        ****     uint16_t i;
 282:main.c        ****     if (corrupted) {
 283:main.c        ****         // set LEDs to "shit really hit the fan"
 284:main.c        ****         dbg_set(0xA);
 285:main.c        **** 
 286:main.c        ****         // fill the first page with 0xFF
 287:main.c        ****         for ( i=0 ; i<PAGESIZE ; i+=2 ) {
 288:main.c        ****             boot_page_fill_safe(i, 0xFFFF);
 289:main.c        ****         }
 290:main.c        ****         boot_page_write_safe(0);
 291:main.c        ****         boot_spm_busy_wait();
 292:main.c        **** 
 293:main.c        ****         // halt
 294:main.c        ****         while(1);
 295:main.c        ****     } else {
 296:main.c        ****         // set LEDs to "shit slightly hit the fan"
 297:main.c        ****         dbg_set(0x9);
 298:main.c        ****     }
GAS LISTING /tmp/cch8wAQa.s 			page 8


 299:main.c        **** 
 300:main.c        ****     // return to waiting for data
 301:main.c        ****     curstate = CST_IDLE;    // reset state machine
 302:main.c        ****     receive_data();
 303:main.c        **** }
