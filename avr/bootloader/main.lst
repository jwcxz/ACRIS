   1:main.c        **** /* A C R I S   P R O J E C T ********
   2:main.c        ****  * LED Controller Bootloader        *
   3:main.c        ****  * http://jwcxz.com/projects/acris  *
   4:main.c        ****  *                                  *
   5:main.c        ****  * J. Colosimo -- http://jwcxz.com/ *
   6:main.c        ****  *                                  *
   7:main.c        ****  * Main bootloader source file      *
   8:main.c        ****  ************************************/
   9:main.c        **** 
  10:main.c        **** /*
  11:main.c        ****  * This bootloader provides the following features:
  12:main.c        ****  *  1. fast startup time (i.e. bootloader->application time)
  13:main.c        ****  *  2. downloading of program to device
GAS LISTING /tmp/ccTXHOTK.s 			page 3


  14:main.c        ****  *  3. set address of instrument
  15:main.c        ****  *  4. set the transmission baud rate (via the divisor)
  16:main.c        ****  *  5. set a mask (only operate on some devices)
  17:main.c        ****  *  6. view the instrument address on the debug LEDs
  18:main.c        ****  *  7. program verification
  19:main.c        ****  *
  20:main.c        ****  *  Transmission is done through a serial protocol:
  21:main.c        ****  *  Fn  Args    Description
  22:main.c        ****  *  ___ _______ ____________________________________________________
  23:main.c        ****  *  170 0       SYNC -- start of a packet
  24:main.c        ****  *
  25:main.c        ****  *  N   0       NOP -- sent to wake bootloader up (or you can use SYNC)
  26:main.c        ****  *
  27:main.c        ****  *  A   1       Set 1-byte address of the device in EEPROM
  28:main.c        ****  *
  29:main.c        ****  *  B   2       [High][Low][Double?] -- set divisor and U2XN of the UART in EEPROM
  30:main.c        ****  *
  31:main.c        ****  *  D   0       Show the high nibble of the instrument address on the debug LEDs
  32:main.c        ****  *
  33:main.c        ****  *  E   0       Show the low nibble of the instrument address on the debug LEDs
  34:main.c        ****  *
  35:main.c        ****  *  M   1       [InstAddr] Instrument address to work with for all following commands
  36:main.c        ****  *                  0xFF - all instruments
  37:main.c        ****  *                  0xF0-0xFE - blocks of 16
  38:main.c        ****  *
  39:main.c        ****  *  P   2       [Addr][Page...] - Send program one page at a time
  40:main.c        ****  *                  To simplify the bootloader, it does NOT take an Intel HEX
  41:main.c        ****  *                  file as an input.  Rather, a special "program" script reads
  42:main.c        ****  *                  the HEX file and outputs the following format:
  43:main.c        ****  *                      [Starting Address][Page][Checksum]
  44:main.c        ****  *                  The checksum is the one's complement of the sum of the
  45:main.c        ****  *                  page stream.
  46:main.c        ****  *
  47:main.c        ****  *                  Note: this means that the stream length depends on the page
  48:main.c        ****  *                  size (whereas Intel HEX files have known lengths).
  49:main.c        ****  *                  Furthermore, it requires that unused bytes be 0-filled or
  50:main.c        ****  *                  something.  I'd rather make the programmer
  51:main.c        ****  *
  52:main.c        ****  *  R   0       BOOT - boot the application
  53:main.c        ****  *
  54:main.c        ****  *  V   1       [Checksum] Verify whole program against checksum.  If
  55:main.c        ****  *              verification fails, write 0xFF to the program start to prevent
  56:main.c        ****  *              the bootloader from loading the application.
  57:main.c        ****  */
  58:main.c        **** 
  59:main.c        **** #include "main.h"
  60:main.c        **** #include "eeprom.h"
  61:main.c        **** #include "dbgled.h"
  62:main.c        **** #include "uart.h"
  63:main.c        **** 
  64:main.c        **** // uart buffer
  65:main.c        **** volatile uint8_t uart_rxbuf[UART_RX_BUFSZ];
  66:main.c        **** volatile uint8_t *uart_rxbuf_iptr = uart_rxbuf;
  67:main.c        **** volatile uint8_t *uart_rxbuf_optr = uart_rxbuf;
  68:main.c        **** volatile uint8_t uart_rxbuf_count = 0;
  69:main.c        **** volatile uint8_t rxen = 1;
  70:main.c        **** 
GAS LISTING /tmp/ccTXHOTK.s 			page 4


  71:main.c        **** // current command state
  72:main.c        **** static uint8_t curstate = CST_IDLE;
  73:main.c        **** 
  74:main.c        **** // page buffer
  75:main.c        **** static uint8_t page_buf[PAGESIZE];
  76:main.c        **** static uint8_t *page_buf_ptr;
  77:main.c        **** static uint16_t page_addr;
  78:main.c        **** 
  79:main.c        **** // instrument address
  80:main.c        **** uint8_t instaddr;
  81:main.c        **** 
  82:main.c        **** // baud rate divisor
  83:main.c        **** static uint16_t baud;
  84:main.c        **** 
  85:main.c        **** // device address mask
  86:main.c        **** static uint8_t mask = AM_ALL;
  87:main.c        **** 
  88:main.c        **** /* Main Loop */
  89:main.c        **** int main(void) {
  90:main.c        ****     MCUCR = (1<<IVCE);
  91:main.c        ****     MCUCR = (1<<IVSEL);
  92:main.c        **** 
  93:main.c        ****     dbg_init();
  94:main.c        ****     dbg_set(0x9);
  95:main.c        **** 
  96:main.c        ****     instaddr = get_addr();
  97:main.c        **** 
  98:main.c        ****     // set up uart for 9600 baud communication with no parity
  99:main.c        **** 	UBRR0H = (uint8_t) (DEF_BAUD_PRESCALE_SLOW>>8);
 100:main.c        **** 	UBRR0L = (uint8_t) DEF_BAUD_PRESCALE_SLOW;
 101:main.c        ****     UCSR0A = ( DEF_BAUD_DOUBLE_SLOW<<U2X0 );
 102:main.c        **** 	UCSR0B = ( _BV(RXCIE0) | _BV(RXEN0) );
 103:main.c        **** 	UCSR0C = ( _BV(UCSZ01) | _BV(UCSZ00) );
 104:main.c        **** 
 105:main.c        ****     // reset the pointers and buffer count
 106:main.c        **** 	uart_rxbuf_iptr = uart_rxbuf;
 107:main.c        **** 	uart_rxbuf_optr = uart_rxbuf;
 108:main.c        ****     uart_rxbuf_count = 0;
 109:main.c        **** 
 110:main.c        ****     sei();
 111:main.c        **** 
 112:main.c        ****     // wait just a bit to get some data
 113:main.c        ****     _delay_ms(250);
 114:main.c        **** 
 115:main.c        ****     // switch to application mode if there's no data on the UART
 116:main.c        ****     if ( !uart_data_rdy() ) {
 117:main.c        ****         cli();
 118:main.c        ****         MCUCR = (1<<IVCE);
 119:main.c        ****         MCUCR &= ~(1<<IVSEL);
 120:main.c        ****         asm("jmp 0000");
 121:main.c        ****     } else {
 122:main.c        ****         // otherwise, go into receive data loop
 123:main.c        ****         receive_data();
 124:main.c        ****     }
 125:main.c        **** 
 126:main.c        ****     return 0;
 127:main.c        **** }
GAS LISTING /tmp/ccTXHOTK.s 			page 5


 128:main.c        **** 
 129:main.c        **** /* Loop, waiting for data */
 130:main.c        **** void receive_data(void) {
 131:main.c        ****     while (1) {
 132:main.c        ****         if ( uart_data_rdy() ) process_rx();
 133:main.c        ****     }
 134:main.c        **** }
 135:main.c        **** 
 136:main.c        **** /* Processed a received byte */
 137:main.c        **** void process_rx(void) {
 138:main.c        ****     uint8_t data, i;
 139:main.c        ****     uint8_t csum = 0;
 140:main.c        ****     data = uart_rx();
 141:main.c        **** 
 142:main.c        ****     if ( data != CMD_NOP ) {
 143:main.c        ****         switch (curstate) {
 144:main.c        ****             case CST_IDLE:
 145:main.c        ****                 if ( data == CMD_SYNC ) curstate = CST_SYNC;
 146:main.c        ****                 else curstate = CST_IDLE;
 147:main.c        ****                 break;
 148:main.c        ****             case CST_SYNC:
 149:main.c        ****                 if ( data == CMD_SYNC ) curstate = CST_SYNC;
 150:main.c        ****                     // if we get a mask request, then always honor it
 151:main.c        ****                 else if ( data == CMD_MASK ) curstate = CST_MASK;
 152:main.c        ****                 else if ( applies_to_me() ) {
 153:main.c        ****                     switch (data) {
 154:main.c        ****                         case CMD_BOOT:
 155:main.c        ****                             cli();
 156:main.c        ****                             MCUCR = (1<<IVCE);
 157:main.c        ****                             MCUCR &= ~(1<<IVSEL);
 158:main.c        ****                             asm("jmp 0000");
 159:main.c        ****                             break;
 160:main.c        ****                             
 161:main.c        ****                         case CMD_DISP_ADDR_H:
 162:main.c        ****                             dbg_set(instaddr>>4);
 163:main.c        ****                             curstate = CST_IDLE;
 164:main.c        ****                             break;
 165:main.c        ****                         case CMD_DISP_ADDR_L:
 166:main.c        ****                             dbg_set(instaddr&0x0F);
 167:main.c        ****                             curstate = CST_IDLE;
 168:main.c        ****                             break;
 169:main.c        **** 
 170:main.c        ****                         case CMD_ADDR:
 171:main.c        ****                             curstate = CST_ADDR;
 172:main.c        ****                             break;
 173:main.c        **** 
 174:main.c        ****                         case CMD_BAUD:
 175:main.c        ****                             curstate = CST_BAUD_H;
 176:main.c        ****                             break;
 177:main.c        **** 
 178:main.c        ****                         case CMD_PROG:
 179:main.c        ****                             curstate = CST_PROG_A_H;
 180:main.c        ****                             break;
 181:main.c        **** 
 182:main.c        ****                         case CMD_VRFY:
 183:main.c        ****                             curstate = CST_VRFY;
 184:main.c        ****                             break;
GAS LISTING /tmp/ccTXHOTK.s 			page 6


 185:main.c        **** 
 186:main.c        ****                         default:
 187:main.c        ****                             curstate = CST_IDLE;
 188:main.c        ****                             break;
 189:main.c        ****                     }
 190:main.c        ****                 } 
 191:main.c        ****                 // otherwise, no action applied to me, so wait for the next
 192:main.c        ****                 // packet (maybe it'll be a new mask)
 193:main.c        ****                 else curstate = CST_IDLE;
 194:main.c        ****                 break;
 195:main.c        **** 
 196:main.c        ****             case CST_MASK:
 197:main.c        ****                 mask = data;
 198:main.c        ****                 curstate = CST_IDLE;
 199:main.c        ****                 break;
 200:main.c        **** 
 201:main.c        ****             case CST_ADDR:
 202:main.c        ****                 addr_set(data);
 203:main.c        ****                 curstate = CST_IDLE;
 204:main.c        ****                 instaddr = get_addr();
 205:main.c        ****                 break;
 206:main.c        **** 
 207:main.c        ****             case CST_BAUD_H:
 208:main.c        ****                 baud = (data << 8);   // high byte of baud rate
 209:main.c        ****                 curstate = CST_BAUD_L;
 210:main.c        ****                 break;
 211:main.c        ****             case CST_BAUD_L:
 212:main.c        ****                 baud |= data;         // low byte of baud rate
 213:main.c        ****                 curstate = CST_BAUD_D;
 214:main.c        ****                 break;
 215:main.c        ****             case CST_BAUD_D:
 216:main.c        ****                 // TODO: save some space by always setting double to 1
 217:main.c        ****                 baud_set(data);
 218:main.c        ****                 curstate = CST_IDLE;
 219:main.c        ****                 break;
 220:main.c        **** 
 221:main.c        ****             case CST_PROG_A_H:
 222:main.c        ****                 //dbg_set(data);
 223:main.c        ****                 page_addr = data << 8;
 224:main.c        ****                 // reset page buffer pointer
 225:main.c        ****                 page_buf_ptr = page_buf;
 226:main.c        ****                 curstate = CST_PROG_A_L;
 227:main.c        ****                 break;
 228:main.c        ****             case CST_PROG_A_L:
 229:main.c        ****                 //dbg_set(data);    // not useful
 230:main.c        ****                 page_addr |= data;
 231:main.c        ****                 curstate = CST_PROG_D;
 232:main.c        ****                 break;
 233:main.c        ****             case CST_PROG_D:
 234:main.c        ****                 *(page_buf_ptr++) = data;
 235:main.c        ****                 if ( page_buf_ptr - page_buf == PAGESIZE ) {
 236:main.c        ****                     // we hit the last byte of the page, so the next byte is the
 237:main.c        ****                     // checksum
 238:main.c        ****                     curstate = CST_PROG_V;
 239:main.c        ****                 } else {
 240:main.c        ****                     curstate = CST_PROG_D;
 241:main.c        ****                 }
GAS LISTING /tmp/ccTXHOTK.s 			page 7


 242:main.c        ****                 break;
 243:main.c        ****             case CST_PROG_V:
 244:main.c        ****                 curstate = CST_IDLE;
 245:main.c        **** 
 246:main.c        ****                 for ( i=0 ; i<PAGESIZE ; i++ ) {
 247:main.c        ****                     csum += page_buf[i];
 248:main.c        ****                 }
 249:main.c        ****                 csum = ~csum;
 250:main.c        **** 
 251:main.c        ****                 //write_page();
 252:main.c        **** 
 253:main.c        ****                 //*
 254:main.c        ****                 if ( csum == data ) {
 255:main.c        ****                     // checksum verifies, so write the page
 256:main.c        ****                     write_page();
 257:main.c        ****                 } else {
 258:main.c        ****                     // damnit...
 259:main.c        ****                     // TODO: we can be slightly smarter (if it's the first address,
 260:main.c        ****                     // we technically haven't corrupted anything yet)
 261:main.c        ****                     give_up(1);
